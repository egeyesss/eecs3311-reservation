<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.yorku.eecs3311.controller.UserDashboardController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="User Dashboard">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
        <VBox.margin>
            <Insets bottom="15.0" />
        </VBox.margin>
    </Label>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="Available Equipment">
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <HBox spacing="10.0">
                        <Button mnemonicParsing="false" onAction="#loadAvailableEquipment" text="Refresh List" />
                        <Button mnemonicParsing="false" onAction="#handleCreateBooking" text="Book Selected Equipment" />
                    </HBox>
                    <TableView fx:id="equipmentTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Equipment ID" />
                            <TableColumn text="Name" />
                            <TableColumn text="Category" />
                            <TableColumn text="Hourly Rate" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="My Bookings">
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                    <HBox spacing="10.0">
                        <Button mnemonicParsing="false" onAction="#loadMyBookings" text="Refresh List" />
                        <Button mnemonicParsing="false" onAction="#handleConfirmArrival" text="Confirm Arrival" />
                        <Button mnemonicParsing="false" onAction="#handleExtendBooking" text="Extend 1 Hr" />
                        <Button mnemonicParsing="false" onAction="#handlePayment" text="Pay Balance" />
                        <Button mnemonicParsing="false" onAction="#handleCancelBooking" text="Cancel Booking" />
                    </HBox>
                    <TableView fx:id="bookingsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Booking ID" />
                            <TableColumn text="Equipment" />
                            <TableColumn text="Start Time" />
                            <TableColumn text="Status" />
                            <TableColumn text="Total Cost" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>